// ================== MODEM ==================
#define TINY_GSM_MODEM_SIM800
#include <TinyGsmClient.h>

// ================== DISPLAY =================
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// ================== GPS =====================
#include <TinyGPSPlus.h>

// ================== PINS ====================
#define GPS_RX_PIN    19  // ESP32 GPIO19 <- GPS TX
#define GPS_TX_PIN    18  // ESP32 GPIO18 -> GPS RX
#define GSM_RX_PIN    16  // ESP32 GPIO16 <- SIM800L TX
#define GSM_TX_PIN    17  // ESP32 GPIO17 -> SIM800L RX
#define LED_PIN       2   // Onboard LED
#define BUTTON_PIN    4   // Emergency button connected between GPIO4 and GND

// ================== OLED ====================
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// ================== SERIALS =================
HardwareSerial SerialGPS(2); // Use ESP32 Hardware Serial 2
HardwareSerial SerialAT(1);  // Use ESP32 Hardware Serial 1

TinyGPSPlus gps;
TinyGsm modem(SerialAT);
TinyGsmClient gsmClient(modem);

// ================== GPRS =====================
const char apn[]  = "web";     // Change APN based on your cellular provider
const char user[] = "";
const char pass[] = "";

// ================== THINGSPEAK ===============
const char* myWriteAPIKey = "BUAFOHPX3VW37K4H"; // Your ThingSpeak API Key

// ================== TARGET PHONE =============
const char targetPhoneNumber[] = "+9779800998787";

// ================== TIMING ===================
unsigned long lastSend   = 0;
const unsigned long sendInterval = 20000; // Server upload every 20 seconds

unsigned long lastDisplayUpdate = 0;
const unsigned long displayInterval = 1000; // Refresh screen every 1 second (Smooth updates)

unsigned long buttonPressedTime = 0;      // Tracks how long the button is held
bool sosSent = false;                     // Latch flag to prevent multi-sending SMS

// ================== DATA =====================
float lat_data = 0.0;
float lng_data = 0.0;
float speed_kmph = 0.0;
int satellites = 0;
float batt = 4.2;   // Simulated battery

// =================================================
void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("\n\n=========================================");
  Serial.println("[SYSTEM] ESP32 GPS Tracker Booting Up...");
  Serial.println("=========================================");

  // ---------- LED & BUTTON ----------
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);
  pinMode(BUTTON_PIN, INPUT_PULLUP); 

  // ---------- OLED ----------
  Wire.begin();
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("[ERROR] SSD1306 OLED allocation failed! Check I2C wiring.");
  } else {
    Serial.println("[OLED] Initialized successfully.");
  }
  
  showMessage("System Booting...");

  // ---------- GPS ----------
  Serial.println("[GPS] Starting Hardware Serial 2 at 9600 baud...");
  SerialGPS.begin(9600, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);

  // ---------- MODEM ----------
  Serial.println("[GSM] Starting Hardware Serial 1 at 115200 baud...");
  SerialAT.begin(115200, SERIAL_8N1, GSM_RX_PIN, GSM_TX_PIN);
  delay(3000);

  Serial.println("[GSM] Initializing SIM800L Modem...");
  showMessage("Initializing GSM...");
  modem.restart();

  Serial.print("[GSM] Waiting for Cellular Network... ");
  if (!modem.waitForNetwork()) {
    Serial.println("FAILED.");
    showMessage("No GSM Network");
  } else {
    Serial.println("CONNECTED.");
    showMessage("GSM Connected");
  }

  Serial.printf("[GSM] Connecting to GPRS APN: '%s'... ", apn);
  if (!modem.gprsConnect(apn, user, pass)) {
    Serial.println("FAILED.");
    showMessage("GPRS Failed");
  } else {
    Serial.println("SUCCESS.");
    showMessage("GPRS Ready");
  }
  
  Serial.println("[SYSTEM] Setup Complete. Entering main loop.\n");
}

// =================================================
void loop() {
  // ---------- FEED GPS ----------
  while (SerialGPS.available()) {
    char c = SerialGPS.read();
    gps.encode(c);
  }

  // Continuously update metrics if GPS data is valid
  if (gps.location.isValid()) {
    lat_data = gps.location.lat();
    lng_data = gps.location.lng();
  }
  if (gps.speed.isValid()) {
    speed_kmph = gps.speed.kmph();
  }
  if (gps.satellites.isValid()) {
    satellites = gps.satellites.value();
  }

  // ---------- EMERGENCY BUTTON CHECK ----------
  checkEmergencyButton();

  // ---------- PERIODIC TASK (OLED Refresh) ----------
  if (millis() - lastDisplayUpdate >= displayInterval) {
    lastDisplayUpdate = millis();
    updateDisplay();
  }

  // ---------- PERIODIC TASK (ThingSpeak Server Send) ----------
  if (millis() - lastSend >= sendInterval) {
    lastSend = millis();

    digitalWrite(LED_PIN, HIGH); 
    
    Serial.println("\n-----------------------------------------");
    Serial.println("[DATA] Preparing to update remote server...");
    Serial.printf("[GPS] Satellites Lock : %d\n", satellites);
    Serial.printf("[GPS] Coordinates     : %.6f, %.6f\n", lat_data, lng_data);
    Serial.printf("[GPS] Speed           : %.1f km/h\n", speed_kmph);
    Serial.printf("[SYS] Battery Level   : %.2f V\n", batt);

    sendToThingSpeak();
    
    digitalWrite(LED_PIN, LOW);

    // FIX: Force an immediate refresh right after the transmissive power spike drops.
    // This wipes away any visual artifacts or screen coordinate shifting instantly.
    updateDisplay();
    lastDisplayUpdate = millis(); 
  }
}

// =================================================
void checkEmergencyButton() {
  if (digitalRead(BUTTON_PIN) == LOW) {
    if (buttonPressedTime == 0) {
      buttonPressedTime = millis(); 
      Serial.println("[ALERT] Emergency button pressed. Hold for 5 seconds...");
    } else if (!sosSent && (millis() - buttonPressedTime >= 5000)) {
      sendEmergencySMS();
      sosSent = true; 
    }
  } else {
    if (buttonPressedTime != 0) {
      Serial.println("[ALERT] Button released.");
    }
    buttonPressedTime = 0;
    sosSent = false;
  }
}

// =================================================
void sendEmergencySMS() {
  digitalWrite(LED_PIN, HIGH);
  showMessage("SENDING SOS!");
  Serial.println("\n=========================================");
  Serial.println("[SOS] EMERGENCY HOLD DETECTED!");
  Serial.println("=========================================");
  
  String message = "EMERGENCY ALERT!\nHelp needed. My current location:\n";
  if (lat_data != 0.0 && lng_data != 0.0) {
    message += "http://maps.google.com/?q=" + String(lat_data, 6) + "," + String(lng_data, 6);
  } else {
    message += "GPS coordinates not available yet (No satellite fix).";
  }
  
  Serial.printf("[SOS] Sending SMS to %s...\n", targetPhoneNumber);
  
  if (modem.sendSMS(targetPhoneNumber, message)) {
    Serial.println("[SOS] SMS Sent Successfully!");
    showMessage("SOS SMS SENT");
  } else {
    Serial.println("[SOS] ERROR: Failed to send SMS.");
    showMessage("SOS FAILED!");
  }
  
  delay(2000); 
  digitalWrite(LED_PIN, LOW);
  updateDisplay();
}

// =================================================
void sendToThingSpeak() {
  if (!modem.isNetworkConnected() || !modem.isGprsConnected()) {
    Serial.println("[GPRS] Connection lost. Attempting to reconnect...");
    if(modem.gprsConnect(apn, user, pass)) {
       Serial.println("[GPRS] Reconnected successfully.");
    } else {
       Serial.println("[GPRS] Reconnect failed. Will retry next cycle.");
       return;
    }
  }

  Serial.print("[HTTP] Connecting to api.thingspeak.com... ");
  if (gsmClient.connect("api.thingspeak.com", 80)) {
    Serial.println("OK");
    
    String url = "/update?api_key=" + String(myWriteAPIKey);
    url += "&field1=" + String(lat_data, 6);
    url += "&field2=" + String(lng_data, 6);
    url += "&field3=" + String(speed_kmph, 2);
    url += "&field4=" + String(satellites);
    url += "&field5=" + String(batt, 2);

    Serial.println("[HTTP] Sending GET Request...");
    
    gsmClient.print(String("GET ") + url + " HTTP/1.1\r\n");
    gsmClient.print("Host: api.thingspeak.com\r\n");
    gsmClient.print("Connection: close\r\n\r\n");

    Serial.print("[HTTP] Waiting for server response... ");
    
    unsigned long timeout = millis();
    int bytesRead = 0;
    while (gsmClient.connected() && millis() - timeout < 5000) {
      // FIX: Continually feed the GPS serial pipeline during this blocking network loop
      // to avoid buffer overflows and coordinate data drops.
      while (SerialGPS.available()) {
        char c = SerialGPS.read();
        gps.encode(c);
      }

      while (gsmClient.available()) {
        gsmClient.read(); 
        bytesRead++;
        timeout = millis(); 
      }
    }
    
    Serial.printf("Done. (%d bytes read)\n", bytesRead);
    Serial.println("[SUCCESS] ThingSpeak Updated.");
    
    batt -= 0.01; 
  } else {
    Serial.println("FAILED.");
    Serial.println("[ERROR] HTTP Connection could not be established.");
  }

  gsmClient.stop();
  delay(1000); // FIX: Safe 100ms delay allowing voltage configurations to settle down cleanly
  Serial.println("[HTTP] Client stopped. Cycle complete.");
}

// =================================================
void updateDisplay() {
  display.clearDisplay();

  // --- TOP STATUS BAR (Inverted Colors) ---
  display.fillRect(0, 0, 128, 14, WHITE);
  display.setTextColor(BLACK, WHITE); 
  display.setTextSize(1);
  display.setCursor(2, 3);
  display.print("SAT: "); 
  display.print(satellites);

  display.setCursor(68, 3);
  if (modem.isGprsConnected()) {
    display.print("GPRS: OK");
  } else {
    display.print("GPRS: --");
  }

  // --- MIDDLE: LARGE SPEED READOUT ---
  display.setTextColor(WHITE, BLACK); 
  display.setTextSize(2);
  display.setCursor(15, 22);
  display.print(speed_kmph, 1); 
  
  display.setTextSize(1);
  display.print(" km/h");

  // --- BOTTOM: GPS COORDINATES ---
  display.drawLine(0, 42, 128, 42, WHITE);
  
  display.setTextSize(1);
  display.setCursor(0, 46);
  display.print("Lat: "); 
  if (lat_data == 0.0) display.print("Waiting..."); 
  else display.print(lat_data, 6); 

  display.setCursor(0, 55); 
  display.print("Lng: ");
  if (lng_data == 0.0) display.print("Waiting..."); 
  else display.print(lng_data, 6); 

  display.display();
}

// =================================================
void showMessage(String msg) {
  display.clearDisplay();
  
  display.drawRect(0, 0, 128, 64, WHITE);
  display.setTextSize(1);
  display.setTextColor(WHITE, BLACK); 
  
  int xPos = (128 - (msg.length() * 6)) / 2;
  if(xPos < 0) xPos = 0;
  
  display.setCursor(xPos, 28);
  display.print(msg); 
  display.display();
  delay(1000); 
}
